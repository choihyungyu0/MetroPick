VITE_APP_NAME=MetroPick AI
# For Vercel deployments, set this to the deployed FastAPI backend origin.
# Do not leave production builds pointing at localhost.
VITE_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Do not put real public data service keys in frontend env files.
# VITE_ variables are exposed to browser code.
# Use a backend/proxy for real API keys.
